Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "colors"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"color1", "=", " ", 
     RowBox[{"Lighter", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<ViridisColor\>\"", "]"}], "[", 
        "0.4", "]"}], ",", " ", "0.2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"color2", "=", " ", 
     RowBox[{"Darker", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<ViridisColor\>\"", "]"}], "[", 
        "0.8", "]"}], ",", " ", "0.1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"color3", "=", 
     RowBox[{"Lighter", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<ViridisColor\>\"", "]"}], "[", 
        "0.1", "]"}], ",", " ", "0.4"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Spherical", " ", "cap", " ", "cut", " ", "open", " ", "and", " ", 
     "varibales", " ", "marked"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SphericalCapOpen", "[", 
      RowBox[{
      "AI_", ",", "Acont_", ",", "openingAngle_", ",", "ringSize_", ",", " ", 
       "viewPoint_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "RI", ",", "RII", ",", "r", ",", "thetaI", ",", "thetaII", ",", 
         "center", ",", "phi"}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"Calculate", " ", "radii", " ", "and", " ", "angles"}], 
        "*)"}], 
       RowBox[{
        RowBox[{"RI", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"Acont", "/", 
           RowBox[{"(", 
            RowBox[{"Pi", " ", 
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"2", " ", "Acont"}], ")"}], "/", "AI"}], "-", 
                  "1"}], ")"}], "^", "2"}]}], ")"}]}], ")"}]}], "]"}]}], ";", 
        RowBox[{"RII", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"Acont", "/", 
           RowBox[{"(", 
            RowBox[{"Pi", " ", 
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"2", " ", "Acont"}], ")"}], "/", 
                   RowBox[{"(", 
                    RowBox[{"1", "-", "AI"}], ")"}]}], "-", "1"}], ")"}], "^",
                 "2"}]}], ")"}]}], ")"}]}], "]"}]}], ";", 
        RowBox[{"r", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"Acont", "/", "Pi"}], "]"}]}], ";", 
        RowBox[{"thetaI", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"2", " ", "Acont"}], ">", "AI"}], ",", 
           RowBox[{"ArcSin", "[", 
            RowBox[{"r", "/", "RI"}], "]"}], ",", 
           RowBox[{"Pi", "-", 
            RowBox[{"ArcSin", "[", 
             RowBox[{"r", "/", "RI"}], "]"}]}]}], "]"}]}], ";", 
        RowBox[{"thetaII", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"2", " ", "Acont"}], ">", 
            RowBox[{"(", 
             RowBox[{"1", "-", "AI"}], ")"}]}], ",", 
           RowBox[{"ArcSin", "[", 
            RowBox[{"r", "/", "RII"}], "]"}], ",", 
           RowBox[{"Pi", "-", 
            RowBox[{"ArcSin", "[", 
             RowBox[{"r", "/", "RII"}], "]"}]}]}], "]"}]}], ";", 
        RowBox[{"(*", 
         RowBox[{
         "Center", " ", "of", " ", "second", " ", "spherical", " ", "cap"}], 
         "*)"}], 
        RowBox[{"center", "=", 
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"Cos", "[", "thetaI", "]"}], " ", "RI"}], "+", 
            RowBox[{
             RowBox[{"Cos", "[", "thetaII", "]"}], " ", "RII"}]}], ")"}]}]}], 
        ";", 
        RowBox[{"(*", 
         RowBox[{"Marking", " ", "the", " ", "radii"}], "*)"}], 
        RowBox[{"phi", "=", 
         RowBox[{"Range", "[", 
          RowBox[{
           RowBox[{"0.5", " ", "Pi"}], ",", 
           RowBox[{"2", " ", "Pi"}], ",", 
           RowBox[{"Pi", "/", "16"}]}], "]"}]}], ";", 
        RowBox[{"inner", "=", "0.01"}], ";", 
        RowBox[{"(*", 
         RowBox[{
         "Plot", " ", "both", " ", "spherical", " ", "caps", " ", "and", " ", 
          "annotations"}], "*)"}], 
        RowBox[{"Show", "[", 
         RowBox[{
          RowBox[{"ParametricPlot3D", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "RI"}], " ", 
               RowBox[{"Cos", "[", "theta", "]"}]}], ",", 
              RowBox[{"RI", " ", 
               RowBox[{"Sin", "[", "theta", "]"}], " ", 
               RowBox[{"Cos", "[", "phi", "]"}]}], ",", 
              RowBox[{"RI", " ", 
               RowBox[{"Sin", "[", "theta", "]"}], " ", 
               RowBox[{"Sin", "[", "phi", "]"}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"phi", ",", "0", ",", "openingAngle"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"theta", ",", "0", ",", "thetaI"}], "}"}], ",", 
            RowBox[{"PlotStyle", "->", 
             RowBox[{"{", 
              RowBox[{"color1", ",", 
               RowBox[{"Opacity", "[", "0.8", "]"}]}], "}"}]}], ",", 
            RowBox[{"Mesh", "->", "None"}], ",", 
            RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", 
          RowBox[{"ParametricPlot3D", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"center", "+", 
               RowBox[{"RII", " ", 
                RowBox[{"Cos", "[", "theta", "]"}]}]}], ",", 
              RowBox[{"RII", " ", 
               RowBox[{"Sin", "[", "theta", "]"}], " ", 
               RowBox[{"Cos", "[", "phi", "]"}]}], ",", 
              RowBox[{"RII", " ", 
               RowBox[{"Sin", "[", "theta", "]"}], " ", 
               RowBox[{"Sin", "[", "phi", "]"}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"phi", ",", "0", ",", "openingAngle"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"theta", ",", "0", ",", "thetaII"}], "}"}], ",", 
            RowBox[{"PlotStyle", "->", 
             RowBox[{"{", 
              RowBox[{"color2", ",", 
               RowBox[{"Opacity", "[", "0.8", "]"}]}], "}"}]}], ",", 
            RowBox[{"Mesh", "->", "None"}], ",", 
            RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", 
          RowBox[{"ParametricPlot3D", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "RI"}], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"0.8", " ", 
                  RowBox[{"Cos", "[", "theta", "]"}]}], "+", "0.1"}], ")"}]}],
               ",", 
              RowBox[{"0.9", " ", "RI", " ", 
               RowBox[{"Sin", "[", "theta", "]"}], " ", 
               RowBox[{"Cos", "[", "phi", "]"}]}], ",", 
              RowBox[{"0.9", " ", "RI", " ", 
               RowBox[{"Sin", "[", "theta", "]"}], " ", 
               RowBox[{"Sin", "[", "phi", "]"}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"phi", ",", "0", ",", 
              RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
            RowBox[{"PlotStyle", "->", 
             RowBox[{"{", 
              RowBox[{"color3", ",", 
               RowBox[{"Opacity", "[", "1", "]"}]}], "}"}]}], ",", 
            RowBox[{"Mesh", "->", "None"}], ",", 
            RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", 
          RowBox[{"Graphics3D", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Black", ",", 
              RowBox[{"Thickness", "[", "ringSize", "]"}], ",", 
              RowBox[{"Line", "[", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"-", 
                    RowBox[{"Cos", "[", "thetaI", "]"}]}], " ", "RI"}], ",", 
                   RowBox[{"RI", " ", 
                    RowBox[{"Sin", "[", "thetaI", "]"}], " ", 
                    RowBox[{"Cos", "[", "phi", "]"}]}], ",", 
                   RowBox[{"RI", " ", 
                    RowBox[{"Sin", "[", "thetaI", "]"}], " ", 
                    RowBox[{"Sin", "[", "phi", "]"}]}]}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"phi", ",", "0", ",", 
                   RowBox[{"2", " ", "Pi"}], ",", "0.01"}], "}"}]}], "]"}], 
               "]"}]}], "}"}], ",", 
            RowBox[{"Boxed", "->", "False"}], ",", 
            RowBox[{"Axes", "->", "False"}]}], "]"}], ",", 
          RowBox[{"Lighting", "->", "\"\<Neutral\>\""}], ",", 
          RowBox[{"Boxed", "->", "False"}], ",", 
          RowBox[{"Axes", "->", "False"}], ",", 
          RowBox[{"ViewPoint", "->", "viewPoint"}], ",", 
          RowBox[{"ViewVertical", "->", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", 
             RowBox[{"-", "1"}]}], "}"}]}]}], "]"}]}]}], "]"}]}], ";"}], "\n",
    "\n"}]}]], "Input",
